{
  "type": "Doc",
  "id": "tasks_management",
  "label": "Task Management System",
  "description": "Iteration-based task management system for tracking task execution through numbered iterations with metrics collection",
  "metadata": {
    "version": "1.0.0",
    "backend": "knowledge_base_system"
  },
  "opts": {
    "render_priority": false,
    "render_toc": true
  },
  "children": {
    "overview": {
      "type": "Doc",
      "id": "overview",
      "label": "Overview",
      "description": "High-level overview of the iteration-based task management system",
      "metadata": {},
      "opts": {
        "render_priority": true,
        "render_toc": false
      },
      "children": {
        "purpose": {
          "type": "Doc",
          "id": "purpose",
          "label": "Purpose",
          "description": "The task management system uses the knowledge base as its state store, persisting task.json with Task model (RenderableModel). Tasks progress through iterations, collecting code and test metrics at each iteration. Iterations stop when metrics no longer change. All state mutations use Pydantic models for validation, and markdown is auto-rendered for human readability.",
          "metadata": {}
        },
        "workflow": {
          "type": "Doc",
          "id": "workflow",
          "label": "Iteration Workflow",
          "description": "Tasks progress through iterations, each collecting metrics. Stop when metrics no longer change.",
          "metadata": {},
          "children": {
            "evolution": {
              "type": "Doc",
              "id": "evolution",
              "label": "Evolution",
              "description": "Task state progression through iterations",
              "metadata": {},
              "children": {
                "linear_progression": {
                  "type": "Doc",
                  "id": "linear_progression",
                  "label": "Linear Progression",
                  "metadata": {
                    "code": "task.json \u2192 [Plan] \u2192 iteration_1 \u2192 iteration_2 \u2192 ... \u2192 iteration_n \u2192 archive"
                  }
                },
                "decision_flow": {
                  "type": "Doc",
                  "id": "decision_flow",
                  "label": "Decision Flow",
                  "metadata": {
                    "code": "[Create] \u2192 [Iteration] \u2192 [Metrics] \u2192 [Changed?] \u2192 YES: [Work] | NO: [Archive]"
                  }
                }
              }
            },
            "steps": {
              "type": "Doc",
              "id": "steps",
              "label": "Process Steps",
              "description": "How each iteration progresses",
              "metadata": {
                "steps": [
                  "1. Create task.json with plan Doc",
                  "2. Complete work: code changes, run tests",
                  "3. Run task_roll.py: collects metrics, creates iteration_N",
                  "4. Check: did metrics change from previous iteration?",
                  "5. If YES: go to step 2 | If NO: archive task"
                ]
              },
              "children": {}
            }
          }
        }
      }
    },
    "scripts": {
      "type": "Doc",
      "id": "scripts",
      "label": "Task Scripts",
      "description": "Four scripts handle core task lifecycle operations: create, roll iterations, collect metrics, and archive",
      "metadata": {},
      "opts": {
        "render_priority": false,
        "render_toc": false
      },
      "children": {
        "task_create": {
          "type": "Doc",
          "id": "task_create",
          "label": "task_create.py",
          "description": "Initialize task.json with plan Doc",
          "metadata": {
            "process": [
              "Fail if task.json exists",
              "Create Task with initial Doc plan",
              "Add created_at, updated_at metadata",
              "Write task.json and auto-render task.md"
            ]
          }
        },
        "task_roll": {
          "type": "Doc",
          "id": "task_roll",
          "label": "task_roll.py",
          "description": "Record iteration completion with metrics",
          "metadata": {
            "process": [
              "Load task.json and parse as Task model",
              "Collect metrics (git diff + pytest)",
              "Create iteration_N with code_stats, tests_stats",
              "Write updated task.json"
            ]
          }
        },
        "task_metrics": {
          "type": "Doc",
          "id": "task_metrics",
          "label": "task_metrics.py",
          "description": "Collect code and test metrics",
          "metadata": {
            "sources": [
              "Code metrics from git diff (added/removed lines, files changed)",
              "Test metrics from pytest (passed/total tests)",
              "Coverage metrics per test"
            ]
          }
        },
        "task_archive": {
          "type": "Doc",
          "id": "task_archive",
          "label": "task_archive.py",
          "description": "Archive completed task to tasks_history/",
          "metadata": {
            "naming_format": "YYYYMMDD-HHMMSS-task-ID.json and .md"
          }
        }
      }
    },
    "json_patch": {
      "type": "Doc",
      "id": "task",
      "label": "Task Model",
      "description": "Root task container with plan and iterations",
      "metadata": {},
      "opts": {
        "render_priority": false,
        "render_toc": false
      },
      "children": {
        "iteration_model": {
          "type": "Doc",
          "id": "iteration_model",
          "label": "Iteration",
          "description": "Single iteration tracking code and test metrics",
          "metadata": {
            "fields": {
              "id": "str - iteration_1, iteration_2, ...",
              "metadata": "Dict - created_at, updated_at",
              "code_stats": "CodeStats - lines added/removed, files changed",
              "tests_stats": "TaskTestMetrics - passed/total tests",
              "coverage_stats_by_tests": "Dict - lines covered per test"
            }
          }
        },
        "code_stats": {
          "type": "Doc",
          "id": "code_stats",
          "label": "CodeStats",
          "description": "Code change metrics from git",
          "metadata": {
            "fields": {
              "added_lines": "int",
              "removed_lines": "int",
              "files_changed": "int"
            }
          }
        },
        "task_test_metrics": {
          "type": "Doc",
          "id": "task_test_metrics",
          "label": "TaskTestMetrics",
          "description": "Test execution metrics from pytest",
          "metadata": {
            "fields": {
              "passed": "int - tests passed",
              "total": "int - total tests",
              "pass_rate": "float - calculated (passed/total)*100"
            }
          }
        }
      }
    },
    "integration": {
      "type": "Doc",
      "id": "integration",
      "label": "State & Integration",
      "description": "How task state is stored and managed using knowledge base system",
      "metadata": {},
      "opts": {
        "render_priority": false,
        "render_toc": false
      },
      "children": {
        "state_storage": {
          "type": "Doc",
          "id": "state_storage",
          "label": "State Storage",
          "description": "Task state persisted in knowledge base",
          "metadata": {
            "format": "task.json - JSON using Task/Iteration models",
            "rendering": "task.md - Auto-rendered markdown from task.json",
            "validation": "Pydantic models validate on load/save"
          }
        },
        "rendering": {
          "type": "Doc",
          "id": "rendering",
          "label": "Rendering",
          "description": "Task and Iteration models render to markdown",
          "metadata": {
            "approach": "Pure abstraction - models handle rendering logic only",
            "methods": "Task.render() and Iteration.render() return markdown strings",
            "file_io": "Separate from models - handled by scripts"
          }
        }
      }
    },
    "examples": {
      "type": "Doc",
      "id": "examples",
      "label": "Examples",
      "description": "Usage examples for task operations",
      "metadata": {},
      "opts": {
        "render_priority": false,
        "render_toc": false
      },
      "children": {
        "create": {
          "type": "Doc",
          "id": "create",
          "label": "Create Task",
          "metadata": {
            "code": "python3 -m tasks_lifecycle.tools.create_task",
            "result": "\u2713 Created task file: task.json",
            "creates": "task.json with Task model (plan Doc + empty iterations)"
          }
        },
        "advance": {
          "type": "Doc",
          "id": "iteration_1",
          "label": "First Iteration",
          "metadata": {
            "code": "python3 -m tasks_lifecycle.tools.task_roll",
            "result": "\u2713 Rolled task with iteration iteration_1\n  Code: +42 -5 (3 files)\n  Tests: 10/12 passed (83.3%)",
            "creates": "iteration_1 entry in task.json with metrics"
          }
        },
        "metrics": {
          "type": "Doc",
          "id": "metrics_collection",
          "label": "Metrics Collection",
          "description": "Metrics are collected automatically by task_roll.py",
          "metadata": {
            "code": "python3 -m tasks_lifecycle.tools.task_metrics",
            "output": "{\n  \"code_stats\": {\"added_lines\": 42, \"removed_lines\": 5, \"files_changed\": 3},\n  \"tests_stats\": {\"passed\": 10, \"total\": 12},\n  \"coverage_stats_by_tests\": {\"test_1\": 45, \"test_2\": 38}\n}"
          }
        },
        "rollback": {
          "type": "Doc",
          "id": "iteration_2",
          "label": "Second Iteration",
          "description": "Run another iteration after changes",
          "metadata": {
            "code": "# Make changes to code\npython3 -m tasks_lifecycle.tools.task_roll",
            "result": "\u2713 Rolled task with iteration iteration_2\n  Code: +15 -2 (2 files)\n  Tests: 11/12 passed (91.7%)",
            "note": "Process repeats until metrics no longer change"
          }
        },
        "archive": {
          "type": "Doc",
          "id": "archive_task",
          "label": "Archive Task",
          "metadata": {
            "code": "python3 -m tasks_lifecycle.tools.task_archive",
            "result": "\u2713 Archived task task_1\n  JSON: tasks_history/20260301-153021-task-task_1.json\n  MD:   tasks_history/20260301-153021-task-task_1.md",
            "creates": "Timestamped files in tasks_history/ directory"
          }
        }
      }
    },
    "metrics_collection": {
      "type": "Doc",
      "id": "metrics_collection",
      "label": "Metrics Collection",
      "description": "Metrics are collected automatically at each iteration via task_metrics.py",
      "metadata": {
        "metrics_types": {
          "code_stats": "Files changed, lines added/removed from git diff",
          "tests_stats": "Number of passed tests vs total tests",
          "coverage_stats_by_tests": "Lines covered per test"
        },
        "stopping_condition": "Task stops iterating when metrics do not change from previous iteration"
      },
      "opts": {
        "render_priority": true,
        "render_toc": false
      }
    }
  }
}