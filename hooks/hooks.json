{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "tool",
        "tool": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_bash.py"
          }
        ]
      },
      {
        "matcher": "tool",
        "tool": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_edit.py"
          }
        ]
      },
      {
        "matcher": "tool",
        "tool": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_write.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_session_start.py"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_session_start.py"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_session_start.py"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_session_start.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_session_end.py"
          }
        ]
      },
      {
        "matcher": "logout",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_session_end.py"
          }
        ]
      },
      {
        "matcher": "prompt_input_exit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_session_end.py"
          }
        ]
      },
      {
        "matcher": "bypass_permissions_disabled",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_session_end.py"
          }
        ]
      },
      {
        "matcher": "other",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_session_end.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_notification.py"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_notification.py"
          }
        ]
      },
      {
        "matcher": "auth_success",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_notification.py"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_notification.py"
          }
        ]
      }
