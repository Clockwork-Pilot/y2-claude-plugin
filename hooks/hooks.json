    "ConfigChange": [
      {
        "matcher": "user_settings",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_config_change.py"
          }
        ]
      },
      {
        "matcher": "project_settings",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_config_change.py"
          }
        ]
      },
      {
        "matcher": "local_settings",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_config_change.py"
          }
        ]
      },
      {
        "matcher": "policy_settings",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_config_change.py"
          }
        ]
      },
      {
        "matcher": "skills",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_config_change.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_user_prompt_submit.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_stop.py"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_teammate_idle.py"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_task_completed.py"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_worktree_create.py"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/handler_worktree_remove.py"
          }
        ]
      }
    ]
  }
}
